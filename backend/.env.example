# =====================================================
# Finanzas — Backend · PLANTILLA de variables de entorno
# Copia este archivo a `.env.dev` (desarrollo) o `.env.prod` (producción)
# y reemplaza los CHANGE_ME por valores reales.
# Estos .env reales están en .gitignore y NUNCA deben subirse a git.
# Las URLs de Prisma se derivan solas de estas partes (ver src/lib/env.ts).
# =====================================================

# ---------- Base de datos PostgreSQL ----------
# En docker el host es el nombre del servicio: "postgres". En local: "localhost".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
# DB global: registro de empresas, super admins, planes y auditoría.
# Cada empresa creada obtiene además su propia DB (finanzas_t_*) automáticamente.
POSTGRES_DB=finanzas_global

# ---------- Seguridad ----------
# Genera con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=1d
# Cifra las credenciales de la BD de cada empresa (AES-256-GCM). 64 caracteres hex.
# Genera con: openssl rand -hex 32
# IMPORTANTE: si cambias esta clave, las conexiones de tenants ya creados
# dejan de poder descifrarse. No la rotes una vez en producción.
TENANT_ENCRYPTION_KEY=CHANGE_ME

# ---------- Aplicación ----------
NODE_ENV=development
PORT=4000
# Dominio(s) del frontend (coma-separados). Ej: https://finanzas.tudominio.com
CORS_ORIGIN=http://localhost:5173

# ---------- Administrador inicial (se crea/actualiza en cada arranque) ----------
# Es el SuperAdmin (dueño de la plataforma): administra las empresas.
SEED_EMAIL=admin@ejemplo.com
SEED_PASSWORD=CHANGE_ME
SEED_NAME=Administrador

# ---------- (Opcional) Primera empresa creada en el primer arranque ----------
# COMPANY_NAME=Mi Empresa
# COMPANY_EMAIL=admin@miempresa.com
# COMPANY_ADMIN_NAME=Administrador
# COMPANY_ADMIN_PASSWORD=CHANGE_ME
