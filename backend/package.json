{
  "name": "finanzas-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "predev": "npm run dev:db:push && npm run dev:bootstrap",
    "dev": "tsx watch --env-file=.env.dev src/index.ts",
    "dev:db:push": "tsx --env-file=.env.dev scripts/db-push.ts",
    "dev:bootstrap": "tsx --env-file=.env.dev scripts/bootstrap.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=prisma/global/schema.prisma && prisma generate --schema=prisma/tenant/schema.prisma",
    "prisma:push:global": "prisma db push --schema=prisma/global/schema.prisma --accept-data-loss",
    "prisma:push:tenant": "prisma db push --schema=prisma/tenant/schema.prisma --accept-data-loss",
    "sync:tenants": "tsx --env-file=.env.dev scripts/sync-tenant-schemas.ts",
    "migrate:multitenant": "tsx scripts/migrate-to-multitenant.ts",
    "seed:superadmin": "tsx scripts/seed-superadmin.ts",
    "bootstrap": "tsx scripts/bootstrap.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^11.3.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
