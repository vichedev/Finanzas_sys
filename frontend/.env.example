# =====================================================
# Finanzas — Frontend · PLANTILLA de variables de entorno
# Copia a `.env.dev` / `.env.prod` (o `.env`) según tu flujo.
# Las VITE_* se leen en tiempo de BUILD.
# =====================================================

# ---------- URL del API ----------
# Mismo dominio (recomendado): "/api"; nginx/Vite hace de proxy al backend.
# Backend en otro dominio: URL completa, ej. https://api.tudominio.com
VITE_API_URL=/api

# ---------- Dominio público del sistema ----------
VITE_APP_URL=http://localhost:5173
